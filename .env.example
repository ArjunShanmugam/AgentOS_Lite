# ─── AgentOS Lite — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── API Security ─────────────────────────────────────────────────────────────
# Bearer token required for task submission endpoints.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENTOS_API_KEY=change-me-generate-a-secure-token

# ── LLM (Google AI Studio) ────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-ai-studio-api-key-here

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development default)
DATABASE_URL=sqlite+aiosqlite:///./data/agentos.db

# PostgreSQL (production) — uncomment and fill in:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentos

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FILE=logs/agentos.jsonl

# ── Agent Settings ────────────────────────────────────────────────────────────
EXECUTOR_AGENT_ID=executor-01
MAX_TASK_ATTEMPTS=3
TASK_TIMEOUT_SECONDS=10
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# ── Executor Config Path ──────────────────────────────────────────────────────
EXECUTOR_CONFIG_PATH=configs/executor-01.yaml

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_SCRAPE_INTERVAL=15
